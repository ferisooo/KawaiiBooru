{
  "name": "kawaii-booru",
  "version": "1.0.0",
  "description": "A glowing kawaii-cyberpunk Danbooru gallery viewer",
  "main": "main.js",
  "scripts": {
    "build": "esbuild renderer/app.jsx --bundle --jsx-factory=React.createElement --jsx-fragment=React.Fragment --outfile=renderer/app.js",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "author": "Feris",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "electron": "^31.0.0",
    "esbuild": "^0.28.0"
  },
  "build": {
    "appId": "com.feris.kawaiibooru",
    "productName": "KawaiiBooru",
    "asar": false,
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build-assets/icon.*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build-assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KawaiiBooru"
    }
  }
}
